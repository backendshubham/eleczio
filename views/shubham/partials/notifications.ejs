<div class="notif-bar" role="region" aria-label="Announcements">
  <div class="notif-marquee-outer">
    <div class="notif-marquee-track">
      <div class="notif-marquee-content">
        <% tickerSegments.forEach(function (seg) { %>
          <span class="notif-seg">
            <% if (seg.link) { %>
            <a href="<%= seg.link %>" target="_blank" rel="noopener noreferrer" class="notif-seg-link">
            <% } %>
              <i class="<%= seg.icon %>" aria-hidden="true"></i>
              <span class="notif-seg-text"><%= seg.text %></span>
            <% if (seg.link) { %>
            </a>
            <% } %>
          </span>
          <span class="notif-sep" aria-hidden="true">✦</span>
        <% }); %>
      </div>
      <div class="notif-marquee-content" aria-hidden="true">
        <% tickerSegments.forEach(function (seg) { %>
          <span class="notif-seg">
            <% if (seg.link) { %>
            <a href="<%= seg.link %>" target="_blank" rel="noopener noreferrer" class="notif-seg-link">
            <% } %>
              <i class="<%= seg.icon %>" aria-hidden="true"></i>
              <span class="notif-seg-text"><%= seg.text %></span>
            <% if (seg.link) { %>
            </a>
            <% } %>
          </span>
          <span class="notif-sep" aria-hidden="true">✦</span>
        <% }); %>
      </div>
    </div>
  </div>
</div>
