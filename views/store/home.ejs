<section class="section" style="padding-top:0;">
  <div class="sec-head sec-head-row">
    <div>
      <div class="sec-tag">Trending Now</div>
      <div class="sec-title">Best-Selling Gift Boxes</div>
      <div class="sec-sub">Handpicked hampers loved by our customers</div>
    </div>
    <a href="/products" class="see-all">See all products →</a>
  </div>

  <div class="occ-tabs">
    <button class="occ-pill on" type="button">All Occasions</button>
    <button class="occ-pill" type="button">Birthday 🎂</button>
    <button class="occ-pill" type="button">Anniversary 💕</button>
    <button class="occ-pill" type="button">Wedding 💍</button>
    <button class="occ-pill" type="button">Corporate 💼</button>
  </div>

  <div class="pgrid">
    <% if (featuredProducts && featuredProducts.length) { %>
      <% featuredProducts.forEach(p => { %>
        <a href="/products/<%= p.id %>" class="pcard">
          <div class="pcard-img" style="background:#FBF0E8;">
            <% if (p.badge) { %>
              <span class="pcard-badge <%= p.badgeClass || 'badge-hot' %>"><%= p.badge %></span>
            <% } %>
            <% if (p.primary_image) { %>
              <img
                src="<%= p.primary_image.image_path %>"
                alt="<%= p.name %>"
                style="max-width:100%;max-height:100%;object-fit:cover;border-radius:24px;"
              />
            <% } else { %>
              🎁
            <% } %>
          </div>
          <div class="pcard-body">
            <div class="pcard-cat"><%= p.occasion || 'Gift' %></div>
            <div class="pcard-name"><%= p.name %></div>
            <% if (p.description) { %>
              <div class="pcard-desc"><%= p.description.slice(0, 90) %>...</div>
            <% } %>
            <div class="pcard-foot">
              <span>
                <span class="pcard-price">₹<%= p.price %></span>
                <% if (p.compare_at_price && p.compare_at_price > p.price) { %>
                  <span class="pcard-old">₹<%= p.compare_at_price %></span>
                <% } %>
              </span>
              <form method="post" action="/cart/add/<%= p.id %>">
                <button class="pcard-add" type="submit">+</button>
              </form>
            </div>
          </div>
        </a>
      <% }) %>
    <% } else { %>
      <p style="color:var(--muted);">No featured products yet. Add some from the admin dashboard.</p>
    <% } %>
  </div>
</section>

<section class="build-band">
  <div class="build-band-l">
    <div class="build-eyebrow">✦ OUR SIGNATURE EXPERIENCE</div>
    <h2>
      Create Your <i>Dream</i><br />Hamper, Your Way
    </h2>
    <p>
      Every great gift starts with intent. Choose the box, pick the contents, add your personal touch — and we handle
      the rest, beautifully.
    </p>
    <div class="build-steps-list">
      <div class="bstep">
        <span class="bstep-n">1</span>
        <span class="bstep-t">Choose your packaging — wooden, acrylic, basket or luxury hamper</span>
      </div>
      <div class="bstep">
        <span class="bstep-n">2</span>
        <span class="bstep-t">Add items from chocolates, toys, mugs, cards &amp; more</span>
      </div>
      <div class="bstep">
        <span class="bstep-n">3</span>
        <span class="bstep-t">Add a personal message or upload a custom photo card</span>
      </div>
      <div class="bstep">
        <span class="bstep-n">4</span>
        <span class="bstep-t">We pack &amp; deliver it — perfectly wrapped, on time</span>
      </div>
    </div>
    <a href="/build-hamper" class="btn-solid" style="margin-top:4px;">Start Building Your Hamper →</a>
  </div>
  <div class="build-band-r">
    <div class="box-preview-card">
      <div class="box-preview-title">Your Custom Hamper Preview</div>
      <div class="box-items-wrap">
        <div class="bxi">
          <div class="bxi-icon">📦</div>
          <div class="bxi-name">Wooden Box</div>
          <div class="bxi-price">₹499</div>
        </div>
        <div class="bxi">
          <div class="bxi-icon">🍫</div>
          <div class="bxi-name">Ferrero Rocher</div>
          <div class="bxi-price">₹299</div>
        </div>
        <div class="bxi">
          <div class="bxi-icon">☕</div>
          <div class="bxi-name">Ceramic Mug</div>
          <div class="bxi-price">₹249</div>
        </div>
        <div class="bxi empty">
