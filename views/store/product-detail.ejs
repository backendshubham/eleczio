<section class="section" style="display:grid;grid-template-columns:360px 1fr;gap:40px;">
  <div style="border-radius:var(--rl);border:1px solid var(--border);background:#fff;padding:16px;display:flex;flex-direction:column;gap:12px;align-items:center;justify-content:flex-start;">
    <div style="width:100%;border-radius:var(--rl);overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--warm);min-height:260px;">
      <% if (primaryImage) { %>
        <img
          src="<%= primaryImage.image_path %>"
          alt="<%= product.name %>"
          style="max-width:100%;max-height:100%;object-fit:cover;"
        />
      <% } else { %>
        <div style="font-size:72px;">🎁</div>
      <% } %>
    </div>
    <% if (images && images.length > 1) { %>
      <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
        <% images.forEach(function(img) { %>
          <div style="width:64px;height:64px;border-radius:14px;overflow:hidden;border:1px solid var(--border);background:#fff;display:flex;align-items:center;justify-content:center;">
            <img
              src="<%= img.image_path %>"
              alt="<%= product.name %>"
              style="width:100%;height:100%;object-fit:cover;"
            />
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
  <div>
    <div class="sec-tag"><%= product.occasion || 'Gift' %></div>
    <h1 class="sec-title" style="font-size:32px;"><%= product.name %></h1>
    <p class="sec-sub" style="margin-top:16px;"><%= product.description %></p>
    <div style="margin-top:24px;font-size:22px;font-weight:700;color:var(--accent);">
      ₹<%= product.price %>
    </div>
    <form method="post" action="/cart/add/<%= product.id %>" style="margin-top:24px;">
      <button type="submit" class="btn-solid">Add to Cart →</button>
    </form>
  </div>
</section>

