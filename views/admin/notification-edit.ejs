<div class="topbar">
  <h1 style="margin:0">Edit notification</h1>
  <a href="/admin/notifications" class="btn btn-ghost">← Back</a>
</div>
<form method="post" action="/admin/notifications/<%= notification._id %>" class="card">
  <div class="row">
    <div class="field"><label>Title EN</label><input name="title_en" value="<%= notification.title && notification.title.en ? notification.title.en : '' %>" required /></div>
    <div class="field"><label>Title HI</label><input name="title_hi" value="<%= notification.title && notification.title.hi ? notification.title.hi : '' %>" required /></div>
  </div>
  <div class="row">
    <div class="field"><label>Body EN</label><textarea name="body_en"><%= notification.body && notification.body.en ? notification.body.en : '' %></textarea></div>
    <div class="field"><label>Body HI</label><textarea name="body_hi"><%= notification.body && notification.body.hi ? notification.body.hi : '' %></textarea></div>
  </div>
  <div class="row">
    <div class="field"><label>Icon</label><input name="icon_class" value="<%= notification.icon_class %>" /></div>
    <div class="field"><label>Sort</label><input type="number" name="sort_order" value="<%= notification.sort_order %>" /></div>
  </div>
  <div class="field"><label>Link</label><input name="link_url" value="<%= notification.link_url %>" /></div>
  <label style="display:flex;align-items:center;gap:8px;font-weight:500">
    <input type="checkbox" name="is_active" <%= notification.is_active ? 'checked' : '' %> /> Active
  </label>
  <div style="margin-top:1rem"><button type="submit" class="btn">Update</button></div>
</form>
