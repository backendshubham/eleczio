<div class="topbar">
  <h1 style="margin:0">Edit member</h1>
  <a href="/admin/members" class="btn btn-ghost">← Back</a>
</div>
<form method="post" action="/admin/members/<%= member._id %>" class="card">
  <div class="field"><label>Name</label><input name="name" value="<%= member.name %>" required /></div>
  <div class="row">
    <div class="field"><label>Role EN</label><input name="role_en" value="<%= member.role && member.role.en ? member.role.en : '' %>" required /></div>
    <div class="field"><label>Role HI</label><input name="role_hi" value="<%= member.role && member.role.hi ? member.role.hi : '' %>" required /></div>
  </div>
  <div class="row">
    <div class="field"><label>Phone</label><input name="phone" value="<%= member.phone %>" required /></div>
    <div class="field"><label>Display</label><input name="phone_display" value="<%= member.phone_display %>" /></div>
  </div>
  <div class="row">
    <div class="field">
      <label>Icon</label>
      <select name="icon_variant">
        <option value="elec" <%= member.icon_variant === 'elec' ? 'selected' : '' %>>Electrical</option>
        <option value="eltr" <%= member.icon_variant === 'eltr' ? 'selected' : '' %>>Electronics</option>
      </select>
    </div>
    <div class="field"><label>Sort</label><input type="number" name="sort_order" value="<%= member.sort_order %>" /></div>
  </div>
  <label style="display:flex;align-items:center;gap:8px;font-weight:500">
    <input type="checkbox" name="is_active" <%= member.is_active ? 'checked' : '' %> /> Active
  </label>
  <div style="margin-top:1rem"><button type="submit" class="btn">Update</button></div>
</form>
