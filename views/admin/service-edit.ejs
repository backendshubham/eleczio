<div class="topbar">
  <h1 style="margin:0">Edit service</h1>
  <a href="/admin/services" class="btn btn-ghost">← Back</a>
</div>
<form method="post" action="/admin/services/<%= service._id %>" class="card">
  <div class="row">
    <div class="field"><label>Title EN</label><input name="title_en" value="<%= service.title && service.title.en ? service.title.en : '' %>" required /></div>
    <div class="field"><label>Title HI</label><input name="title_hi" value="<%= service.title && service.title.hi ? service.title.hi : '' %>" required /></div>
  </div>
  <div class="row">
    <div class="field"><label>Description EN</label><textarea name="description_en" required><%= service.description && service.description.en ? service.description.en : '' %></textarea></div>
    <div class="field"><label>Description HI</label><textarea name="description_hi" required><%= service.description && service.description.hi ? service.description.hi : '' %></textarea></div>
  </div>
  <div class="row">
    <div class="field" style="grid-column:1/-1"><label>URL slug</label><input name="slug" value="<%= service.slug || '' %>" required /></div>
  </div>
  <div class="row">
    <div class="field"><label>Detail page EN</label><textarea name="detail_en" rows="8"><%= service.detail && service.detail.en ? service.detail.en : '' %></textarea></div>
    <div class="field"><label>Detail page HI</label><textarea name="detail_hi" rows="8"><%= service.detail && service.detail.hi ? service.detail.hi : '' %></textarea></div>
  </div>
  <div class="row">
    <div class="field"><label>Icon</label><input name="iconClass" value="<%= service.iconClass %>" /></div>
    <div class="field"><label>Sort</label><input type="number" name="sort_order" value="<%= service.sort_order %>" /></div>
  </div>
  <label style="display:flex;align-items:center;gap:8px;font-weight:500">
    <input type="checkbox" name="is_active" <%= service.is_active ? 'checked' : '' %> /> Active
  </label>
  <div style="margin-top:1rem"><button type="submit" class="btn">Update</button></div>
</form>
