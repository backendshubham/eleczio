<div class="adm-hd">
  <div class="adm-hd-l">
    <h2><%= product ? 'Edit Product' : 'Add Product' %></h2>
    <% if (typeof totalProducts !== 'undefined') { %>
      <p style="margin-top:6px;font-size:13px;color:var(--muted);">
        Currently <strong><%= totalProducts %></strong> products in inventory
      </p>
    <% } %>
  </div>
</div>

<div class="adm-card">
  <form
    method="post"
    enctype="multipart/form-data"
    action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>"
  >
    <% if (typeof error !== 'undefined' && error) { %>
      <div style="margin-bottom:16px;padding:10px 14px;border-radius:var(--r);background:#FEE2E2;color:#991B1B;font-size:13px;">
        <%= error %>
      </div>
    <% } %>
    <div class="fg">
      <label class="fl">Name</label>
      <input class="fi" name="name" value="<%= product ? product.name : '' %>" required />
    </div>
    <div class="fg">
      <label class="fl">Description</label>
      <textarea class="fi" name="description"><%= product ? product.description : '' %></textarea>
    </div>
    <div class="fg">
      <label class="fl">Price *</label>
      <input class="fi" type="number" step="0.01" min="0" name="price" value="<%= product ? product.price : '' %>" required />
    </div>
    <div class="fg">
      <label class="fl">Occasion *</label>
      <input class="fi" name="occasion" value="<%= product ? product.occasion : '' %>" required />
    </div>
    <div class="fg">
      <label class="fl">Recipient *</label>
      <input class="fi" name="recipient" value="<%= product ? product.recipient : '' %>" required />
    </div>
    <div class="fg">
      <label class="fl">Box Type *</label>
      <input class="fi" name="box_type" value="<%= product ? product.box_type : '' %>" required />
    </div>
    <div class="fg">
      <label class="fl">Images (you can select multiple) *</label>
      <input class="fi" type="file" name="images" multiple <%= product && product.image_path ? '' : 'required' %> />
      <% if (product && product.image_path) { %>
        <div style="font-size:12px;color:var(--muted);margin-top:4px;">
          Currently stored: <%= product.image_path %>
        </div>
      <% } %>
    </div>
    <% if (product) { %>
      <div class="fg">
        <label class="fl">
          <input type="checkbox" name="is_active" <%= product.is_active ? 'checked' : '' %> />
          Active
        </label>
      </div>
    <% } %>
    <button class="btn-solid" type="submit" style="margin-top:16px;">Save</button>
  </form>
</div>

