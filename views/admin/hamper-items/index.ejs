<div class="adm-hd">
  <div class="adm-hd-l">
    <h2>Hamper Builder Items</h2>
    <p>Configure packaging and add-on items shown in the builder.</p>
  </div>
</div>

<div class="adm-card" style="margin-bottom:18px;">
  <div class="adm-card-hd">
    <span class="adm-card-title">Add Item</span>
  </div>
  <form method="post">
    <div class="fg">
      <label class="fl">Name</label>
      <input class="fi" name="name" required />
    </div>
    <div class="fg">
      <label class="fl">Group (packaging/addon)</label>
      <input class="fi" name="group" placeholder="packaging or addon" required />
    </div>
    <div class="fg">
      <label class="fl">Price</label>
      <input class="fi" type="number" step="0.01" name="price" required />
    </div>
    <div class="fg">
      <label class="fl">Icon</label>
      <input class="fi" name="icon" />
    </div>
    <button class="btn-solid" type="submit" style="margin-top:14px;">Add</button>
  </form>
</div>

<div class="adm-card">
  <div class="adm-card-hd">
    <span class="adm-card-title">Existing Items</span>
  </div>
  <% items.forEach(i => { %>
    <div class="prod-row">
      <div class="pr-thumb"><%= i.icon || '🎁' %></div>
      <div class="pr-info">
        <div class="pr-nm"><%= i.name %></div>
        <div class="pr-cat"><%= i.group %> · ₹<%= i.price %></div>
      </div>
      <form method="post" action="/admin/hamper-items/<%= i.id %>/delete">
        <button class="ib" type="submit">🗑</button>
      </form>
    </div>
  <% }) %>
</div>

